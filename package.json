{
    "name": "evernorth-provider-playwright-e2e",
    "version": "1.0.0",
    "description": "Evernorth Provider Portal End-to-End Testing Framework with Playwright",
    "main": "index.js",
    "type": "module",
    "scripts": {
        "test": "playwright test",
        "testCucumber": "cucumber-js --config=cucumber.config.ts",
        "test:sit": "playwright test --config=playwright.sit.config.ts",
        "test:prod": "playwright test --config=playwright.prod.config.ts",
        "test:epp": "playwright test --config=playwright.epp.config.ts",
        "test:headed": "playwright test --headed",
        "test:chrome:headed": "playwright test --project=chromium --config=playwright.config.ts --headed",
        "test:debug": "playwright test --debug",
        "test:ui": "playwright test --ui",
        "test:smoke": "playwright test --grep @smoke",
        "test:regression": "playwright test --grep @regression",
        "test:chromium": "playwright test --project=chromium --headed",
        "test:firefox": "playwright test --project=firefox --headed",
        "test:webkit": "playwright test --project=webkit --headed",
        "report": "playwright show-report",
        "report:allure": "allure serve allure-results",
        "install:browsers": "playwright install",
        "lint": "eslint src/**/*.ts",
        "format": "prettier --write src/**/*.ts"
    },
    "dependencies": {
        "@cucumber/cucumber": "^12.7.0",
        "dotenv": "^16.3.1",
        "inversify": "^6.0.0",
        "reflect-metadata": "^0.2.2"
    },
    "devDependencies": {
        "@playwright/test": "^1.58.2",
        "@types/node": "^20.0.0",
        "@typescript-eslint/eslint-plugin": "^6.0.0",
        "@typescript-eslint/parser": "^6.0.0",
        "allure-playwright": "^2.15.1",
        "eslint": "^8.0.0",
        "mailosaur": "^8.0.0",
        "prettier": "^3.0.0",
        "typescript": "^5.3.3"
    },
    "keywords": [
        "playwright",
        "e2e",
        "testing",
        "typescript",
        "epp",
        "evernorth",
        "provider-portal"
    ],
    "author": "QE Team",
    "License": "MIT"
}
